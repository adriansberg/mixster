# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/shitster

# Auth Secret (generate with: openssl rand -base64 32)
AUTH_SECRET=your-secret-key-min-32-characters-long-change-this-in-production

# OAuth - Google (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth - GitHub (optional)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# OAuth - Apple (optional)
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# Email - Resend (optional, used in production)
RESEND_API_KEY=
EMAIL_FROM=noreply@example.com

# App
PUBLIC_APP_URL=http://localhost:5173
NODE_ENV=development
